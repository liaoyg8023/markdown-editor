{
  "manifest_version": 3,
  "name": "Markdown Editor",
  "version": "1.0.0",
  "description": "简洁强大的 Markdown 编辑与预览工具",
  "author": "liaoyg8023",
  "homepage_url": "https://github.com/liaoyg8023/markdown-editor",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Markdown Editor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
